{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "androsamp/filament-rich-editor-highlight",
    "description": "Filament Rich Editor highlight plugin (TipTap) for FilamentPHP.",
    "license": "MIT",
    "keywords": [
        "filament",
        "filamentphp",
        "rich-editor",
        "tiptap",
        "color",
        "highlight",
        "laravel",
        "plugin"
    ],
    "require": {
        "php": "^8.1",
        "filament/forms": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "Androsamp\\FilamentRichEditorHighlight\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Androsamp\\FilamentRichEditorHighlight\\FilamentRichEditorHighlightServiceProvider"
            ]
        }
    },
    "support": {
        "issues": "https://github.com/AndroSamp-it/filament-rich-editor-highlight/issues",
        "source": "https://github.com/AndroSamp-it/filament-rich-editor-highlight"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}


